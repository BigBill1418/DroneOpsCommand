# DroneOpsCommand — systemd service for auto-start on boot
#
# Install:
#   sudo cp droneops.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable droneops
#   sudo systemctl start droneops
#
# Logs:
#   journalctl -u droneops -f
#
[Unit]
Description=DroneOpsCommand — Drone Operations Management Platform
Documentation=https://github.com/BigBill1418/DroneOpsCommand
After=docker.service network-online.target
Requires=docker.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/DroneOpsCommand
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
ExecReload=/usr/bin/docker compose restart
# Give containers up to 120s to start (Ollama model load can be slow)
TimeoutStartSec=120
TimeoutStopSec=60
# Auto-restart the compose stack if it exits unexpectedly
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
